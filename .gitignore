# Dependencies
node_modules/

# Build output
dist/

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.DS_Store

# Env
.env
.env.local

# Source documents (kept locally, not tracked in git)
*.pdf
*.xlsx
*.xls

# Stale .js compiled outputs that occasionally reappear next to the real .ts
# sources (e.g. when an editor accidentally runs tsc with no outDir).
src/**/*.js
!src/**/*.config.js
