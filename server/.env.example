# Server environment variables
# Copy this to .env and fill in real values — never commit .env

# ── Neon DB ───────────────────────────────────────────────────────────────────
# Get from Neon console: Project → Connection string (pooled)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must include the GitHub Pages URL
# in production so the sd_session cookie is allowed cross-origin.
# Local dev:  http://localhost:5173
# Production: https://<your>.github.io
CORS_ORIGINS=http://localhost:5173,https://pavan-gattupalli-savii.github.io

# ── Admin ─────────────────────────────────────────────────────────────────────
# Used to approve community submissions — keep this secret
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=change-this-to-a-long-random-string

# ── Auth: JWT signing secret ──────────────────────────────────────────────────
# Used to sign session cookies (HS256). Rotate to invalidate every session.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-string

# ── Auth: SMTP (sends sign-in OTP emails) ─────────────────────────────────────
# Gmail "App Password" works out of the box: https://myaccount.google.com/apppasswords
# Leave SMTP_* unset to log codes to stdout (dev only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=System Design Roadmap <you@gmail.com>
